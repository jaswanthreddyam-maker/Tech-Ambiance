# Tech Ambiance Studio Enterprise Environment Variables
# Copy this file to .env and configure your Supabase Project URL and Anon Key

# Supabase Project Credentials (Found in Supabase Console -> Project Settings -> API)
VITE_SUPABASE_URL=https://your-supabase-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-jwt-key
